{
    "name": "interaction-design-foundation/coding-standard",
    "description": "IxDF coding standard: PHP_CodeSniffer rules and shared PHP-CS-Fixer configuration.",
    "license": "MIT",
    "type": "phpcodesniffer-standard",
    "require": {
        "php": "^8.4",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "friendsofphp/php-cs-fixer": "^3.89",
        "slevomat/coding-standard": "^8.29",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.4",
        "rector/rector": "^2.5",
        "vimeo/psalm": "^6.16"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "IxDFCodingStandard\\": "IxDFCodingStandard"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "IxDFCodingStandard\\": "tests"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "sort-packages": true
    },
    "scripts": {
        "cs": ["@php-cs-fixer", "@cs:fix"],
        "cs:fix": "phpcbf -p --colors --cache=.cache/phpcs",
        "php-cs-fixer": "php-cs-fixer fix --no-interaction",
        "rector": "rector",
        "sa": "@psalm",
        "psalm": "psalm --config=psalm.xml",
        "psalm:bl": "@psalm --set-baseline=psalm-baseline.xml --long-progress --no-cache",
        "test": "phpunit"
    }
}
